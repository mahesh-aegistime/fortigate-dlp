    edit "Indian Aadhaar number"
        config entries
            edit 1
                set type "regex"
                set pattern "\\b[2-9]{1}[0-9]{3}\\s?[0-9]{4}\\s?[0-9]{4}\\b"
            next
            edit 2
                set type "regex"
                set pattern "\\b[2-9]{1}[0-9]{3}\\s[0-9]{4}\\s[0-9]{4}\\b"
            next
            edit 3
                set type "regex"
                set pattern "\\b[2-9][0-9]{11}\\b"
            next
        end
    next

    edit "Indian Pan"
        config entries
            edit 1
                set type "regex"
                set pattern "\\b[A-Z]{5}[0-9]{4}[A-Z]{1}\\b"
            next
            edit 2
                set type "regex"
                set pattern "\\b[a-zA-Z]{5}[0-9]{4}[a-zA-Z]{1}\\b"
