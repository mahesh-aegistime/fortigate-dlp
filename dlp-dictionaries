#Open fortigate CLI and past below cmd. This will add keyword dictionary to fortigate.

config dlp dictionary
    edit "patient"
        config entries
            edit 1
                set type "keyword"
                set pattern "patient"
                set ignore-case enable
            next
        end
    next

