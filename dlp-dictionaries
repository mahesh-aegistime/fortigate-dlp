    next

    edit "Indian Voter ID"
        config entries
            edit 1
                set type "regex"
                set pattern "\\b[A-Z]{3}[0-9]{7}\\b"
            next
            edit 2
                set type "regex"
                set pattern "\\b[a-zA-Z]{3}[0-9]{7}\\b"
            next
            edit 3
                set type "regex"
                set pattern "\\b[A-Z]{3}[- ]?[0-9]{7}\\b"
            next
        end
    next
